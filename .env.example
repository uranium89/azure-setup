# =============================================================================
# Paperclip – Docker Environment Variables
# Sao chép file này thành .env và điền các giá trị thực
#   cp .env.example .env
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PAPERCLIP_PORT=3100

# ── Deployment Mode ──────────────────────────────────────────────────────────
# authenticated  → yêu cầu đăng nhập
# public         → mở tất cả không cần đăng nhập
PAPERCLIP_DEPLOYMENT_MODE=authenticated

# URL public của server (phải đặt nếu dùng mode authenticated)
# VD: https://paperclip.example.com
PAPERCLIP_PUBLIC_URL=https://your-domain.com

# ── Instance ─────────────────────────────────────────────────────────────────
PAPERCLIP_INSTANCE_ID=production

# ── Secrets ──────────────────────────────────────────────────────────────────
# Sinh key ngẫu nhiên: openssl rand -hex 32
# QUAN TRỌNG: lưu key này lại, mất key = mất toàn bộ secrets được mã hoá
PAPERCLIP_SECRETS_MASTER_KEY=REPLACE_WITH_openssl_rand_hex_32

PAPERCLIP_SECRETS_STRICT_MODE=true

# ── Telemetry ────────────────────────────────────────────────────────────────
PAPERCLIP_TELEMETRY_DISABLED=1

# ── LLM API Keys (tuỳ chọn) ──────────────────────────────────────────────────
# Chỉ cần nếu dùng adapter claude hoặc codex trực tiếp
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Domain (dùng bởi setup-docker.sh) ───────────────────────────────────────
DOMAIN=your-domain.com
ADMIN_EMAIL=admin@your-domain.com
